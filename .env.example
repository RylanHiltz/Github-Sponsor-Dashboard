
# --- EXAMPLE .ENV FILE ---

# Github Personal Access Token
PAT=your_github_pat_here

# Optional alias for PAT (supported by the code as well)
# GITHUB_TOKEN=your_github_token_here

# --- GitHub App Authentication (optional, replaces PAT) ---
# If these are set, the backend will automatically use a GitHub App installation
# token (auto-refreshed) instead of PAT/GITHUB_TOKEN.
#
# Required:
# - GITHUB_APP_ID:            App ID from your GitHub App settings
# - GITHUB_APP_INSTALLATION_ID: Installation ID of the app installation
# - Private key: set ONE of the following
#
GITHUB_APP_ID=your_github_app_id
GITHUB_APP_INSTALLATION_ID=your_github_app_installation_id

# Option A: Paste the PEM contents. Use literal \n for newlines.
# Example:
# GITHUB_APP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----"
GITHUB_APP_PRIVATE_KEY=

# Option B: Point to the downloaded private key file (.pem)
GITHUB_APP_PRIVATE_KEY_PATH=/absolute/path/to/your/private-key.pem

# Optional but recommended (helps GitHub identify requests)
GITHUB_USER_AGENT=Github-Sponsor-Dashboard

# Database Sensitive Info
host=your_db_host
port=your_db_port
user=your_db_user
password=your_db_password
dbname=your_db_name

# Email for OpenStreetMap Header (Part of TOS: to identify the application and its user)
email=your_email@example.com

# OpenAI API Key (Gender Inference)
API_KEY=your_openai_api_key

# GitHub username and password for authentication token
# (pronouns arent visible unless signed into a github user)
# - MAKE SURE USER DOES NOT HAVE 2FA OR PASSKEY LOGIN 
gh_username=your_github_username
gh_password=your_github_password
